# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# ── ONOS Controller ───────────────────────────────────────────────────────────
# IP address of the PC running ONOS (control network interface)
VITE_ONOS_HOST=192.168.1.1
VITE_ONOS_PORT=8181
VITE_ONOS_USER=onos
VITE_ONOS_PASSWORD=rocks

# ── Dashboard mode ────────────────────────────────────────────────────────────
# Set to "false" to connect to a real ONOS controller
# Set to "true" to run with simulated data (default)
VITE_DEMO_MODE=true

# ── Polling intervals ─────────────────────────────────────────────────────────
VITE_TOPOLOGY_POLL_MS=5000      # How often to refresh topology (devices/links/hosts)
VITE_FLOWS_POLL_MS=3000         # How often to refresh flow rules
VITE_METRICS_POLL_MS=2000       # How often to refresh port statistics
